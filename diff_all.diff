+    /**
+     * Preview the next payroll cycle before opening it.
+     */
+    public function previewNextCycle(Request $request)
+    {
+        $latestCycle = PayrollCycle::orderBy('start_date', 'desc')->first();
+        if (!$latestCycle) {
+            $nextPeriodDate = Carbon::create(2026, 6, 1);
+        } else {
